# ============================================
# FAL.AI SETTINGS
# ============================================

FAL_API_KEY="your_fal_api_key_here"

# Image Generation Models
FAL_IMAGE_MODEL="fal-ai/flux/schnell"
FAL_IMAGE_MODEL_FREE="fal-ai/flux-lora"

# Video Generation Models
FAL_VIDEO_MODEL="fal-ai/veo3.1/fast/image-to-video"
FAL_VIDEO_MODEL_FREE="fal-ai/minimax/hailuo-2.3-fast/standard/image-to-video"

# ============================================
# OPENROUTER SETTINGS
# ============================================

OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Text Generation Models
OPENROUTER_MODEL="openai/chatgpt"
OPENROUTER_MODEL_FREE="x-ai/grok-4.1-fast:free"

# ============================================
# GOOGLE GEMINI SETTINGS
# ============================================

GOOGLE_GEMINI_API_KEY="your_google_gemini_api_key_here"

# ============================================
# FALLBACK MODEL CONFIGURATION
# ============================================

# Primary models for story generation (comma-separated)
# These models will be tried first for text generation
FALLBACK_STORY_PRIMARY="x-ai/grok-4.1-fast,anthropic/claude-3-haiku,gemini-pro"

# Fallback models for story generation (comma-separated)
# These models will be used if primary models fail
FALLBACK_STORY_FALLBACK="meta-llama/llama-3.1-8b-instruct,mistralai/mistral-7b-instruct"

# Primary models for video prompt generation (comma-separated)
FALLBACK_PROMPTS_PRIMARY="x-ai/grok-4.1-fast,anthropic/claude-3-haiku,gemini-pro"

# Fallback models for video prompt generation (comma-separated)
FALLBACK_PROMPTS_FALLBACK="meta-llama/llama-3.1-8b-instruct,mistralai/mistral-7b-instruct"

# Maximum retry attempts for fallback mechanisms
FALLBACK_MAX_RETRIES="3"

# ============================================
# LANGUAGE SETTINGS
# ============================================

# Interface language (en - English, ru - Russian)
# Default: en
LANGUAGE="en"

# ============================================
# TELEGRAM BOT SETTINGS
# ============================================

# Telegram Bot API token (required to run the bot)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Comma-separated list of allowed Telegram User IDs (optional, leave empty to allow all)
# Example: TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"
TELEGRAM_ALLOWED_USER_IDS=""
